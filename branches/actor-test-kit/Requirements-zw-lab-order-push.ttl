<http://mohcc.gov.zw/fhir/lab/Basic/zw-lab-order-push> a fhir:Basic ;
  fhir:nodeRole fhir:treeRoot ;
  fhir:id [ fhir:v "zw-lab-order-push"] ; # 
  fhir:text [
     fhir:status [ fhir:v "generated" ] ;
     fhir:div [ fhir:v "<div xmlns=\"http://www.w3.org/1999/xhtml\"><p class=\"res-header-id\"><b>Generated Narrative: Requirements zw-lab-order-push</b></p><a name=\"zw-lab-order-push\"> </a><a name=\"hczw-lab-order-push\"> </a><p>These requirements apply to the following actors: </p><ul><li><a href=\"ActorDefinition-lab-order-placer.html\">Lab Order Placer</a></li><li><a href=\"ActorDefinition-lab-order-repository.html\">Lab Order Repository</a></li></ul><table class=\"grid\"><tr><td><b><a name=\"order-push-01\"> </a></b>Order bundle conformance</td><td>SHALL</td><td><div><p>The Lab Order Placer SHALL submit orders as a transaction Bundle conforming to the <a href=\"StructureDefinition-zw-lab-order-bundle.html\">ZWLabOrderBundle</a> profile, carrying a ZWLabTask, ZWLabServiceRequest, ZWLabPatient and any ZWSpecimen resources.</p>\n</div></td></tr><tr><td><b><a name=\"order-push-02\"> </a></b>Transaction processing</td><td>SHALL</td><td><div><p>The Lab Order Repository SHALL process the submission as a FHIR transaction (<code>POST [base]</code>) and return a <code>transaction-response</code> Bundle with success status for every entry.</p>\n</div></td></tr><tr><td><b><a name=\"order-push-03\"> </a></b>Validation of submissions</td><td>SHALL</td><td><div><p>The Lab Order Repository SHALL reject submissions that do not conform to the ZWLabOrderBundle profile with an HTTP 4xx response carrying an OperationOutcome.</p>\n</div></td></tr></table></div>"^^rdf:XMLLiteral ]
  ] ; # 
