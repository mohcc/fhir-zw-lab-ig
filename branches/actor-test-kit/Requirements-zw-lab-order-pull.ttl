<http://mohcc.gov.zw/fhir/lab/Basic/zw-lab-order-pull> a fhir:Basic ;
  fhir:nodeRole fhir:treeRoot ;
  fhir:id [ fhir:v "zw-lab-order-pull"] ; # 
  fhir:text [
     fhir:status [ fhir:v "generated" ] ;
     fhir:div [ fhir:v "<div xmlns=\"http://www.w3.org/1999/xhtml\"><p class=\"res-header-id\"><b>Generated Narrative: Requirements zw-lab-order-pull</b></p><a name=\"zw-lab-order-pull\"> </a><a name=\"hczw-lab-order-pull\"> </a><p>These requirements apply to the following actors: </p><ul><li><a href=\"ActorDefinition-lab-order-fulfiller.html\">Lab Order Fulfiller</a></li><li><a href=\"ActorDefinition-lab-order-repository.html\">Lab Order Repository</a></li></ul><table class=\"grid\"><tr><td><b><a name=\"order-pull-01\"> </a></b>Order search</td><td>SHALL</td><td><div><p>The Lab Order Repository SHALL support searching Task by <code>status</code> and ServiceRequest by <code>subject</code>, returning <code>searchset</code> Bundles whose entries conform to <a href=\"StructureDefinition-zw-lab-task.html\">ZWLabTask</a> and <a href=\"StructureDefinition-zw-lab-service-request.html\">ZWLabServiceRequest</a>.</p>\n</div></td></tr><tr><td><b><a name=\"order-pull-02\"> </a></b>Order claiming</td><td>SHALL</td><td><div><p>The Lab Order Fulfiller SHALL claim an order by updating the Task status following the FHIR workflow state machine (<code>requested</code> → <code>accepted</code>/<code>rejected</code> → <code>in-progress</code> → <code>completed</code>), and the Lab Order Repository SHALL support Task update.</p>\n</div></td></tr></table></div>"^^rdf:XMLLiteral ]
  ] ; # 
