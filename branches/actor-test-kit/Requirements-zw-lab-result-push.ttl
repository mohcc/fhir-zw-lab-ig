  fhir:text [
     fhir:status [ fhir:v "generated" ] ;
     fhir:div [ fhir:v "<div xmlns=\"http://www.w3.org/1999/xhtml\"><p class=\"res-header-id\"><b>Generated Narrative: Requirements zw-lab-result-push</b></p><a name=\"zw-lab-result-push\"> </a><a name=\"hczw-lab-result-push\"> </a><p>These requirements apply to the following actors: </p><ul><li><a href=\"ActorDefinition-lab-result-provider.html\">Lab Result Provider</a></li><li><a href=\"ActorDefinition-lab-result-repository.html\">Lab Result Repository</a></li></ul><table class=\"grid\"><tr><td><b><a name=\"result-push-01\"> </a></b>Report document conformance</td><td>SHALL</td><td><div><p>The Lab Result Provider SHALL submit results as a document Bundle conforming to the <a href=\"StructureDefinition-zw-lab-report-bundle.html\">ZWLabReportBundle</a> profile, including a legally attested ZWLabReportComposition (ZW.LAB.A.DE80/DE82).</p>\n</div></td></tr><tr><td><b><a name=\"result-push-02\"> </a></b>Document storage</td><td>SHALL</td><td><div><p>The Lab Result Repository SHALL store the submitted report document whole (<code>POST [base]/Bundle</code>) so the signed-off snapshot remains retrievable as submitted.</p>\n</div></td></tr><tr><td><b><a name=\"result-push-03\"> </a></b>Order linkage</td><td>SHALL</td><td><div><p>The contained ZWLabDiagnosticReport SHALL reference the originating ZWLabServiceRequest via <code>basedOn</code>.</p>\n</div></td></tr></table></div>"^^rdf:XMLLiteral ]
  ] ; # 
